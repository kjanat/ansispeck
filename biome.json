{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true,
		"defaultBranch": "master"
	},
	"files": {
		"includes": ["**", "!!**/dist"]
	},
	"formatter": {
		"enabled": false
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"recommended": true
			},
			"performance": {
				"recommended": true
			},
			"style": {
				"recommended": true,
				"useTemplate": "off"
			}
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"recommended": true,
				"organizeImports": "off",
				"useSortedInterfaceMembers": "on"
			}
		}
	},
	"overrides": [
		{ "includes": ["**/*.jsonc"], "json": { "parser": { "allowComments": true, "allowTrailingCommas": true } } }
	]
}

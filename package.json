{
	"name": "ansispeck",
	"version": "0.1.0",
	"description": "Sub-kilobyte terminal ANSI color formatting.",
	"keywords": [
		"terminal",
		"colors",
		"ansi",
		"formatting",
		"cli",
		"console"
	],
	"repository": "kjanat/ansispeck",
	"license": "0BSD",
	"author": "Kaj Kowalski <info@kajkowalski.nl> (https://github.com/kjanat)",
	"type": "module",
	"imports": {
		"#dist/ansispeck": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"#dist/ansispeck/auto": {
			"types": "./dist/auto.d.ts",
			"default": "./dist/auto.js"
		},
		"#dist/ansispeck/raw": {
			"types": "./dist/raw.d.ts",
			"default": "./dist/raw.js"
		},
		"#dist/ansispeck/noop": {
			"types": "./dist/noop.d.ts",
			"default": "./dist/noop.js"
		},
		"#dist/ansispeck/safe": {
			"types": "./dist/safe.d.ts",
			"default": "./dist/safe.js"
		},
		"#dist/ansispeck/rope": {
			"types": "./dist/rope.d.ts",
			"default": "./dist/rope.js"
		}
	},
	"exports": {
		".": "./dist/index.js",
		"./auto": "./dist/auto.js",
		"./noop": "./dist/noop.js",
		"./raw": "./dist/raw.js",
		"./rope": "./dist/rope.js",
		"./safe": "./dist/safe.js",
		"./package.json": "./package.json"
	},
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"bd": "tsdown",
		"bd:ci": "CI=1 tsdown",
		"fmt": "dprint fmt",
		"prepack": "just prepack",
		"postpack": "just postpack",
		"prepublishOnly": "just prepublishOnly",
		"test": "bun test",
		"typecheck": "tsgo --noEmit"
	},
	"devDependencies": {
		"@arethetypeswrong/core": "^0.18",
		"@biomejs/biome": "^2",
		"@types/bun": "^1.3",
		"@types/node": "^25",
		"@typescript/native-preview": "^7.0.0-dev.20260301.1",
		"ansi-colors": "^4.1.3",
		"chalk": "^5.6.2",
		"colorette": "^2.0.20",
		"dprint": "latest",
		"kleur": "^4.1.5",
		"mitata": "^1.0.34",
		"picocolors": "^1.1.1",
		"publint": "^0.3",
		"rust-just": "^1.46.0",
		"tsdown": "0.21.0-beta.2",
		"typescript": "^5"
	},
	"packageManager": "bun@1.3.10",
	"volta": {
		"node": "25.7.0"
	}
}

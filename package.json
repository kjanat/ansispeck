{
	"name": "femtocolors",
	"version": "0.1.0",
	"description": "Sub-kilobyte terminal ANSI color formatting. Smaller than picocolors.",
	"keywords": [
		"terminal",
		"colors",
		"ansi",
		"formatting",
		"cli",
		"console"
	],
	"repository": "github:kjanat/femtocolors",
	"license": "MIT",
	"author": "Kaj Kowalski <info@kajkowalski.nl> (https://github.com/kjanat)",
	"type": "module",
	"exports": {
		".": "./dist/index.mjs",
		"./package.json": "./package.json"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"bd": "tsdown",
		"dev": "tsdown --watch",
		"fmt": "dprint fmt",
		"lint": "biome check src/",
		"prepack": "bun --bun bd -l error && dprint fmt README.md >/dev/null",
		"postpack": "git restore README.md >/dev/null",
		"prepublishOnly": "bun test && bun --bun typecheck",
		"tar": "bun pm pack --quiet | awk 'NF{line=$0} END{print line}'",
		"test": "bun test",
		"typecheck": "tsgo --noEmit"
	},
	"devDependencies": {
		"@arethetypeswrong/core": "^0.18",
		"@biomejs/biome": "^2",
		"@types/bun": "^1.3",
		"@types/node": "^25",
		"@typescript/native-preview": "^7.0.0-dev.20260301.1",
		"dprint": "latest",
		"publint": "^0.3",
		"tsdown": "0.21.0-beta.2",
		"typescript": "^5"
	},
	"packageManager": "bun@1.3.10"
}

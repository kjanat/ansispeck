{
	"name": "ansispeck",
	"version": "0.1.0",
	"description": "Sub-kilobyte terminal ANSI color formatting.",
	"keywords": [
		"terminal",
		"colors",
		"ansi",
		"formatting",
		"cli",
		"console"
	],
	"repository": "kjanat/ansispeck",
	"license": "0BSD",
	"author": "Kaj Kowalski <info@kajkowalski.nl> (https://github.com/kjanat)",
	"type": "module",
	"exports": {
		".": "./dist/index.js",
		"./package.json": "./package.json"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"bd": "tsdown",
		"bench": "bun bench:bun; bun bench:node",
		"bench:bun": "bun --bun bench.ts",
		"bench:node": "node bench.ts",
		"dev": "tsdown --watch",
		"fmt": "dprint fmt",
		"lint": "biome check src/",
		"prepack": "bun --bun bd -l error && bun scripts/prepack.ts && bunx prettier README.md --write >/dev/null",
		"postpack": "git restore package.json README.md >/dev/null",
		"prepublishOnly": "bun test && bun --bun typecheck",
		"tar": "bun pm pack --quiet | awk 'NF{line=$0} END{print line}'",
		"test": "bun test",
		"typecheck": "tsgo --noEmit"
	},
	"devDependencies": {
		"@arethetypeswrong/core": "^0.18",
		"@biomejs/biome": "^2",
		"@types/bun": "^1.3",
		"@types/node": "^25",
		"@typescript/native-preview": "^7.0.0-dev.20260301.1",
		"ansi-colors": "^4.1.3",
		"chalk": "^5.6.2",
		"colorette": "^2.0.20",
		"dprint": "latest",
		"kleur": "^4.1.5",
		"mitata": "^1.0.34",
		"picocolors": "^1.1.1",
		"publint": "^0.3",
		"tsdown": "0.21.0-beta.2",
		"typescript": "^5"
	},
	"packageManager": "bun@1.3.10",
	"volta": {
		"node": "25.7.0"
	}
}

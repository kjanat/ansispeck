{
	"name": "ansispeck",
	"version": "0.0.0",
	"description": "ANSI that slips in and gets to work.",
	"keywords": [
		"ansispeck",
		"terminal",
		"colors",
		"ansi",
		"formatting",
		"cli",
		"console",
		"hyperlinks",
		"osc8",
		"no-hyperlinks",
		"dreamcli"
	],
	"repository": "kjanat/ansispeck",
	"license": "0BSD",
	"author": "Kaj Kowalski <info@kajkowalski.nl> (https://github.com/kjanat)",
	"type": "module",
	"imports": {
		"#*": "./src/*.ts",
		"#ansispeck": "./src/index.ts",
		"#ansispeck/*": "./src/*.ts",
		"#ansispeck-dist": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"#ansispeck-dist/*": {
			"types": "./dist/*.d.ts",
			"default": "./dist/*.js"
		},
		"#bench/*": "./benchmarks/*.ts",
		"#internal/*.ts": "./src/internal/*.ts",
		"#pkg": "./package.json"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./auto": {
			"types": "./dist/auto.d.ts",
			"default": "./dist/auto.js"
		},
		"./noop": {
			"types": "./dist/noop.d.ts",
			"default": "./dist/noop.js"
		},
		"./raw": {
			"types": "./dist/raw.d.ts",
			"default": "./dist/raw.js"
		},
		"./rope": {
			"types": "./dist/rope.d.ts",
			"default": "./dist/rope.js"
		},
		"./safe": {
			"types": "./dist/safe.d.ts",
			"default": "./dist/safe.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"/dist",
		"/CHANGELOG.md",
		"/LICENSE",
		"/README.md",
		"/jsr.json",
		"/package.json"
	],
	"workspaces": [
		"."
	],
	"scripts": {
		"bd": "run -q build",
		"bench": "run -s bench:bun bench:node",
		"bench:bun": "bun --bun bench.ts",
		"bench:node": "node bench.ts",
		"build": "bun --bun tsdown",
		"build:quiet": "bun --bun tsdown -l error",
		"deno:check": "deno check src/",
		"deno:doc": "deno doc --import-map import_map.json --no-npm --name=\"$(jq -r '.exports | .[]? // .' jsr.json)\"",
		"deno:doc:html": "run -q deno:doc --html --private --strip-trailing-html --output=./.denodocs/ $(jq -r '.exports | .[]? // .' jsr.json) 2>/dev/null",
		"deno:doc:json": "mkdir -p .denodocs; run deno:doc --json $(jq -r '.exports | .[]? // .' jsr.json) 2>/dev/null > .denodocs/documentation.json",
		"deno:doc:lint": "run deno:doc --lint $(jq -r '.exports[]' jsr.json)",
		"deno:lint": "deno lint src/",
		"dev": "run build --watch",
		"fmt": "dprint fmt",
		"lint": "biome check src/",
		"prepare": "bun ./importmapify.config.ts",
		"prepublishOnly": "run -p test typecheck",
		"tar": "run -q build:quiet && bun ./scripts/pack.ts",
		"test": "bun test",
		"typecheck": "bunx @typescript/native --noEmit"
	},
	"overrides": {
		"typescript": "<7"
	},
	"devDependencies": {
		"@arethetypeswrong/core": "^0.18.5",
		"@biomejs/biome": "^2.5.4",
		"@types/bun": "^1.3.14",
		"@types/node": "26.1.1",
		"@typescript/native": "npm:typescript@^7",
		"ansi-colors": "^4.1.3",
		"chalk": "^5.6.2",
		"colorette": "^2.0.20",
		"dprint": "0.55.2",
		"dreamcli": "npm:@kjanat/dreamcli@3.0.0-rc.11",
		"importmapify": "^1.6.0",
		"kleur": "^4.1.5",
		"mitata": "^1.0.34",
		"picocolors": "^1.1.1",
		"publint": "^0.3.21",
		"runner-run": "0.20.0",
		"rust-just": "^1.57.0",
		"sort-package-json": "^4.0.0",
		"tsdown": "0.22.11",
		"typescript": "<7"
	},
	"packageManager": "bun@1.3.14",
	"volta": {
		"node": "26.3.0",
		"npm": "11.16.0"
	}
}

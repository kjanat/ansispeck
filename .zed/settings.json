// Folder-specific settings
//
// For a full list of overridable settings, and general information on folder-specific settings,
// see the documentation: https://zed.dev/docs/configuring-zed#settings-files
{
	"formatter": [
		{ "external": { "command": "dprint", "arguments": ["fmt", "--stdin", "{buffer_path}"] } },
		{ "language_server": { "name": "dprint" } }
	],
	"prettier": { "allowed": false },
	"languages": {
		"TypeScript": {
			"language_servers": ["typescript-ls", "biome", "deno", "..."],
			"formatter": [
				{ "language_server": { "name": "biome" } },
				{ "external": { "command": "dprint", "arguments": ["fmt", "--stdin", "{buffer_path}"] } }
			],
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": true,
				"source.useSortedInterfaceMembers.biome": true
			}
		}
	},
	"lsp": {
		"biome": {
			"settings": {
				"config_path": "./biome.jsonc",
				"require_config_file": true,
				"assist": {
					"enabled": true,
					"actions": {
						"source": {
							"preset": "recommended",
							"organizeImports": {
								"options": {
									"groups": [":NODE:", ":BUN:", ":PACKAGE:", ":ALIAS:", ":PATH:"],
									"identifierOrder": "lexicographic",
									"sortBareImports": false,
								},
								"level": "on"
							},
							"useSortedInterfaceMembers": "on"
						}
					}
				}
			}
		},
		"deno": {
			"settings": {
				"deno": {
					"enable": true,
					"importMap": "./import_map.json"
				}
			}
		}
	}
}
